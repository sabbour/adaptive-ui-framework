{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": "."
  },
  "references": [
    { "path": "packages/core" },
    { "path": "packages/azure-pack" },
    { "path": "packages/github-pack" },
    { "path": "packages/google-maps-pack" },
    { "path": "packages/google-flights-pack" },
    { "path": "packages/travel-data-pack" },
    { "path": "apps/demo" }
  ],
  "files": []
}
