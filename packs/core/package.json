{
  "name": "@sabbour/adaptive-ui-core",
  "version": "1.2.0",
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./css/adaptive.css": "./src/css/adaptive.css",
    "./icons/*": "./src/icons/*"
  },
  "files": [
    "src",
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "main": "src/index.ts",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./src/index.ts"
      },
      "./css/adaptive.css": "./src/css/adaptive.css",
      "./icons/*": "./src/icons/*"
    }
  },
  "scripts": {
    "build": "tsc -b --noEmit",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.6.1",
    "@monaco-editor/react": "^4.7.0",
    "@types/prismjs": "^1.26.6",
    "monaco-editor": "^0.55.0",
    "prismjs": "^1.30.0"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sabbour/adaptive-ui-framework.git",
    "directory": "packs/core"
  },
  "devDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.0"
  }
}
